# BLOCO 08 — EXTRAÇÃO DE ENTIDADES NOMEADAS (NER)
# =============================================================================
# Identifica e extrai entidades relevantes para operações bancárias:
# Pessoas (PER), Organizações (ORG), Localidades (LOC), Datas (DATE), etc.
#
# LABELS SpaCy pt_core_news_lg:
#   PER  → Pessoas físicas
#   ORG  → Organizações e empresas
#   LOC  → Localidades (cidades, estados, países)
#   MISC → Miscelânea (eventos, produtos, etc.)
#
# NOTA: CPF e CNPJ não são reconhecidos nativamente pelo SpaCy.
#       Para extração de CPF/CNPJ, usar regex complementar (vide função abaixo).

import re  # Necessário para extração de padrões estruturados (CPF, CNPJ, etc.)

# Padrões regex para entidades financeiras estruturadas
REGEX_CPF = r"\d{3}\.?\d{3}\.?\d{3}-?\d{2}"
REGEX_CNPJ = r"\d{2}\.?\d{3}\.?\d{3}/?\d{4}-?\d{2}"
REGEX_AGENCIA = r"[Aa]g[eê]ncia[\s:]*(\d{4,5})"
REGEX_CONTA = r"[Cc]onta[\s:]*(\d{5,10})"


def extrair_entidades(texto: str, nlp_model=None) -> dict:
    """
    Extrai entidades nomeadas e padrões estruturados de um texto.

    Combina NER do SpaCy com extração por regex para capturar tanto
    entidades linguísticas (nomes, organizações) quanto dados estruturados
    (CPF, CNPJ, número de conta bancária).

    Args:
        texto (str): Texto do documento para análise.
        nlp_model: Pipeline SpaCy carregado. Usa variável global `nlp` se None.

    Returns:
        dict: Dicionário com listas de entidades por categoria:
              {
                "pessoas": [...],
                "organizacoes": [...],
                "localidades": [...],
                "datas": [...],
                "cpfs": [...],
                "cnpjs": [...],
                "agencias": [...],
                "contas": [...]
              }

    Exemplo:
        >>> resultado = extrair_entidades("João Silva, CPF 123.456.789-00, Recife-PE")
        >>> resultado["pessoas"]
        ['João Silva']
        >>> resultado["cpfs"]
        ['123.456.789-00']
    """
    model = nlp_model or nlp

    # Inicializa dicionário de resultados
    entidades = {
        "pessoas": [],
        "organizacoes": [],
        "localidades": [],
        "datas": [],
        "cpfs": [],
        "cnpjs": [],
        "agencias": [],
        "contas": []
    }

    if not texto or not texto.strip():
        logger.warning("Texto vazio passado para extrair_entidades.")
        return entidades

    # --- Extração via SpaCy NER ---
    doc = model(texto)
    for entidade in doc.ents:
        texto_ent = entidade.text.strip()
        label = entidade.label_

        if label == "PER":
            entidades["pessoas"].append(texto_ent)
        elif label == "ORG":
            entidades["organizacoes"].append(texto_ent)
        elif label == "LOC":
            entidades["localidades"].append(texto_ent)
        elif label in ("DATE", "TIME"):
            entidades["datas"].append(texto_ent)

    # --- Extração via Regex (padrões estruturados) ---
    entidades["cpfs"] = re.findall(REGEX_CPF, texto)
    entidades["cnpjs"] = re.findall(REGEX_CNPJ, texto)
    entidades["agencias"] = re.findall(REGEX_AGENCIA, texto)
    entidades["contas"] = re.findall(REGEX_CONTA, texto)

    # Remove duplicatas mantendo ordem de aparição
    for chave in entidades:
        entidades[chave] = list(dict.fromkeys(entidades[chave]))

    logger.debug(f"Entidades extraídas: {entidades}")
    return entidades


