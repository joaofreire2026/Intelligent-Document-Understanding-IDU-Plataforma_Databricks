# BLOCO 11 — BANCO VETORIAL FAISS
# =============================================================================
# FAISS (Facebook AI Similarity Search) armazena e indexa embeddings para
# recuperação eficiente por similaridade vetorial.
#
# Tipos de índice FAISS:
#   IndexFlatL2    → Busca exata por distância Euclidiana (L2). Mais preciso,
#                    mais lento para grandes volumes. OK para < 1M documentos.
#   IndexFlatIP    → Produto interno (equivale a cosine similarity com vetores normalizados)
#   IndexIVFFlat   → Busca aproximada (ANN). Mais rápido para grandes volumes.
#
# Recomendação para produção com > 100k documentos: usar IndexIVFFlat ou IndexHNSW.

def criar_indice_faiss(dimensao: int = EMBEDDING_DIM) -> faiss.Index:
    """
    Cria e retorna um índice FAISS vazio para busca por distância L2.

    Para vetores normalizados (L2 norm = 1), distância L2 e produto interno
    são equivalentes, portanto IndexFlatL2 com normalize_embeddings=True
    é equivalente a cosine similarity.

    Args:
        dimensao (int): Dimensão dos vetores de embedding (default: 384 para MiniLM).

    Returns:
        faiss.IndexFlatL2: Índice FAISS pronto para receber vetores.
    """
    indice = faiss.IndexFlatL2(dimensao)
    logger.info(f"Índice FAISS criado. Dimensão: {dimensao}. Total vetores: {indice.ntotal}")
    return indice


def adicionar_ao_indice(indice: faiss.Index, embeddings: np.ndarray) -> faiss.Index:
    """
    Adiciona embeddings ao índice FAISS.

    Args:
        indice (faiss.Index): Índice FAISS existente.
        embeddings (np.ndarray): Array de shape (N, dim) com float32.

    Returns:
        faiss.Index: Índice atualizado com os novos vetores.
    """
    # Garante que os embeddings estão no formato correto
    embeddings_f32 = np.array(embeddings, dtype="float32")

    # Reshape se for um único vetor (1D → 2D)
    if embeddings_f32.ndim == 1:
        embeddings_f32 = embeddings_f32.reshape(1, -1)

    indice.add(embeddings_f32)
    logger.info(f"{len(embeddings_f32)} vetor(es) adicionado(s). Total no índice: {indice.ntotal}")
    return indice


def buscar_similares(
    indice: faiss.Index,
    consulta: str,
    modelo=None,
    k: int = 5
) -> tuple:
    """
    Realiza busca semântica por similaridade no índice FAISS.

    Vetoriza a consulta e encontra os k documentos mais similares
    usando distância L2 (equivalente a cosine similarity com vetores normalizados).

    Args:
        indice (faiss.Index): Índice FAISS populado com embeddings.
        consulta (str): Texto da consulta em linguagem natural.
        modelo: Modelo SentenceTransformer (usa global se None).
        k (int): Número de resultados mais similares a retornar.

    Returns:
        tuple: (distancias, indices) onde:
               - distancias: array (1, k) com as distâncias L2
               - indices: array (1, k) com os índices dos docs mais similares

    Exemplo:
        >>> D, I = buscar_similares(index, "Qual o CPF do cliente?", k=3)
        >>> print(f"Documento mais similar: índice {I[0][0]}, distância {D[0][0]:.4f}")
    """
    if indice.ntotal == 0:
        logger.error("Índice FAISS está vazio. Adicione documentos antes de buscar.")
        return np.array([[]]), np.array([[]])

    # Gera embedding da consulta
    embedding_consulta = gerar_embedding(consulta, modelo)
    embedding_consulta = embedding_consulta.reshape(1, -1)  # FAISS requer 2D

    # Limita k ao número de documentos disponíveis
    k_efetivo = min(k, indice.ntotal)

    distancias, indices = indice.search(embedding_consulta, k_efetivo)

    logger.info(f"Busca semântica: '{consulta[:50]}...' → {k_efetivo} resultado(s)")
    return distancias, indices


