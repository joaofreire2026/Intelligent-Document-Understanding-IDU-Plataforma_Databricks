# Pipeline de normalização textual: limpeza, padronização e remoção de ruído.
# Esta etapa é crítica para a qualidade dos embeddings e da NER.

def limpar_texto(texto: str, remover_stopwords: bool = False) -> str:
    """
    Normaliza e limpa o texto extraído de documentos.

    Operações realizadas:
        1. Conversão para letras minúsculas
        2. Remoção de quebras de linha e espaços extras
        3. Strip de espaços nas bordas
        4. (Opcional) Remoção de stopwords em português

    Args:
        texto (str): Texto bruto extraído do documento.
        remover_stopwords (bool): Se True, remove stopwords do português.
                                  Use apenas para classificação/indexação,
                                  NÃO para NER (perde contexto gramatical).

    Returns:
        str: Texto normalizado e limpo.

    Exemplo:
        >>> limpar_texto("  João Silva\\nCPF 123.456.789-00  ")
        'joão silva cpf 123.456.789-00'
    """
    if not isinstance(texto, str):
        logger.warning(f"Entrada inválida para limpar_texto: tipo {type(texto)}")
        return ""

    # Normalização básica
    texto = texto.lower()           # Padroniza caixa
    texto = texto.replace("\n", " ") # Remove quebras de linha
    texto = texto.replace("\r", " ") # Remove carriage returns (Windows)
    texto = texto.replace("\t", " ") # Remove tabs
    # Colapsa múltiplos espaços em um único
    while "  " in texto:
        texto = texto.replace("  ", " ")
    texto = texto.strip()           # Remove espaços nas bordas

    # Remoção opcional de stopwords (APENAS para tarefas de classificação/busca)
    if remover_stopwords:
        stop_words = set(stopwords.words("portuguese"))
        tokens = word_tokenize(texto, language="portuguese")
        tokens_filtrados = [t for t in tokens if t not in stop_words]
        texto = " ".join(tokens_filtrados)

    return texto


