# BLOCO 09 — GERAÇÃO DE EMBEDDINGS
# =============================================================================
# Transforma texto em vetores numéricos densos (embeddings) para
# permitir busca semântica por similaridade.
#
# Diferença entre busca por palavras-chave e busca semântica:
#   - Keyword: "contrato" encontra apenas documentos com a palavra "contrato"
#   - Semântica: "acordo financeiro" também encontra documentos sobre contratos
#
# O modelo 'paraphrase-multilingual-MiniLM-L12-v2' produz:
#   - Vetores de 384 dimensões
#   - Suporte a mais de 50 idiomas (incluindo pt-BR)
#   - Boa performance em tarefas de similaridade semântica

def gerar_embedding(texto: str, modelo=None) -> np.ndarray:
    """
    Gera o vetor de embedding para um texto usando SentenceTransformer.

    Args:
        texto (str): Texto a ser vetorizado. Máx. ~512 tokens (truncado automaticamente).
        modelo: Instância do SentenceTransformer. Usa `modelo_embedding` global se None.

    Returns:
        np.ndarray: Array de float32 com shape (EMBEDDING_DIM,).
                    Retorna array de zeros em caso de texto inválido.
    """
    m = modelo or modelo_embedding

    if not texto or not texto.strip():
        logger.warning("Texto vazio — retornando embedding zero-vector.")
        return np.zeros(EMBEDDING_DIM, dtype="float32")

    # encode() aceita string ou lista de strings
    # normalize_embeddings=True → L2 normalização (útil para cosine similarity)
    embedding = m.encode(texto, normalize_embeddings=True)
    return embedding.astype("float32")


def gerar_embeddings_batch(textos: list, modelo=None, batch_size: int = 32) -> np.ndarray:
    """
    Gera embeddings para uma lista de textos em batch (mais eficiente).

    Args:
        textos (list[str]): Lista de textos para vetorizar.
        modelo: Instância SentenceTransformer (usa global se None).
        batch_size (int): Tamanho do batch para inferência. Ajustar conforme GPU/CPU.

    Returns:
        np.ndarray: Matriz de shape (len(textos), EMBEDDING_DIM).
    """
    m = modelo or modelo_embedding
    embeddings = m.encode(
        textos,
        batch_size=batch_size,
        normalize_embeddings=True,
        show_progress_bar=len(textos) > 100  # Exibe barra apenas para grandes volumes
    )
    return embeddings.astype("float32")


