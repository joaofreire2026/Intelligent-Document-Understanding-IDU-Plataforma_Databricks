# =============================================================================
# BLOCO 10 — CHUNKING (LangChain Text Splitter)
# =============================================================================
# Divide documentos longos em fragmentos (chunks) menores para alimentar
# o pipeline RAG (Retrieval-Augmented Generation) com o LLM.
#
# Por que dividir em chunks?
#   LLMs têm janela de contexto limitada (ex: 4k, 8k, 32k tokens).
#   Documentos bancários podem ter dezenas de páginas.
#   Chunks com sobreposição preservam contexto entre fragmentos adjacentes.
#
# Parâmetros:
#   chunk_size=500    → ~80-100 palavras por chunk (bom para documentos bancários)
#   chunk_overlap=50  → 10% de sobreposição para não perder contexto entre chunks

splitter = RecursiveCharacterTextSplitter(
    chunk_size=CHUNK_SIZE,
    chunk_overlap=CHUNK_OVERLAP,
    # Separadores em ordem de prioridade: parágrafo > linha > frase > palavra
    separators=["\n\n", "\n", ". ", " ", ""]
)


def dividir_em_chunks(texto: str) -> list:
    """
    Divide um texto longo em chunks menores para processamento RAG.

    Usa RecursiveCharacterTextSplitter do LangChain, que tenta dividir
    no nível mais natural (parágrafos → linhas → frases → palavras).

    Args:
        texto (str): Texto completo do documento.

    Returns:
        list[str]: Lista de chunks de texto com sobreposição configurada.

    Exemplo:
        >>> chunks = dividir_em_chunks(texto_longo)
        >>> print(f"{len(chunks)} chunks gerados, média de {sum(len(c) for c in chunks)//len(chunks)} chars/chunk")
    """
    if not texto or not texto.strip():
        return []

    chunks = splitter.split_text(texto)
    logger.debug(f"Texto dividido em {len(chunks)} chunks (chunk_size={CHUNK_SIZE}, overlap={CHUNK_OVERLAP})")
    return chunks


