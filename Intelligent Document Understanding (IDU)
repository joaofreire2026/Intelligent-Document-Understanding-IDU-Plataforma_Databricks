#   - Adicionar categoria "DESCONHECIDO" para documentos não classificados

# Mapeamento expandido: tipo → lista de termos indicadores
KEYWORDS_POR_TIPO = {
    "RG": ["registro geral", "carteira de identidade", "rg", "ssp", "sspds"],
    "CPF": ["cpf", "cadastro de pessoa física", "receita federal"],
    "CNH": ["carteira nacional de habilitação", "cnh", "habilitação", "detran"],
    "Comprovante de Residência": ["comprovante de residência", "conta de luz", "conta de água", "iptu"],
    "Holerite": ["holerite", "contracheque", "folha de pagamento", "salário líquido"],
    "Contrato Bancário": ["contrato bancário", "abertura de conta", "limite de crédito", "agência"],
    "Declaração de Imposto de Renda": ["declaração de imposto de renda", "irpf", "receita federal"],
    "Comprovante de Renda": ["comprovante de renda", "renda mensal", "rendimento"],
    "Extrato Bancário": ["extrato bancário", "saldo disponível", "extrato de conta"],
    "Comprovante PIX": ["pix", "chave pix", "transferência instantânea"],
    "TED": ["ted", "transferência eletrônica disponível"],
    "DOC": ["doc", "documento de ordem de crédito"]
}


def classificar_documento(texto: str, keywords_map: dict = None) -> dict:
    """
    Classifica o tipo documental com base em palavras-chave.

    Percorre o mapeamento de tipos → keywords e pontua cada tipo
    pelo número de termos encontrados no texto. Retorna o tipo com
    maior pontuação como classificação principal.

    Args:
        texto (str): Texto do documento (preferencialmente já limpo/normalizado).
        keywords_map (dict): Mapeamento tipo → lista de keywords.
                             Usa KEYWORDS_POR_TIPO global se None.

    Returns:
        dict: {
            "tipo": str,         # Classificação principal
            "confianca": float,  # Score normalizado (0.0 a 1.0)
            "todos_scores": dict # Score de cada tipo para análise
        }
        Retorna tipo "DESCONHECIDO" se nenhuma keyword for encontrada.

    Exemplo:
        >>> resultado = classificar_documento("Carteira Nacional de Habilitação DETRAN")
        >>> resultado["tipo"]
        'CNH'
    """
    kmap = keywords_map or KEYWORDS_POR_TIPO
    texto_normalizado = texto.lower()

    scores = {}
    for tipo, keywords in kmap.items():
        # Conta quantas keywords do tipo aparecem no texto
        hits = sum(1 for kw in keywords if kw.lower() in texto_normalizado)
        if hits > 0:
            scores[tipo] = hits

    if not scores:
        return {
            "tipo": "DESCONHECIDO",
            "confianca": 0.0,
            "todos_scores": {}
        }

    # Tipo com maior número de keywords encontradas
    tipo_principal = max(scores, key=scores.get)
    max_score = scores[tipo_principal]
    total_keywords = len(kmap[tipo_principal])

    return {
        "tipo": tipo_principal,
        "confianca": round(max_score / total_keywords, 2),  # Score normalizado
        "todos_scores": scores
    }


