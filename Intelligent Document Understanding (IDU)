# Carrega e disponibiliza globalmente os modelos de linguagem.
# O carregamento antecipado evita latência nas etapas subsequentes.

def carregar_modelo_spacy(nome_modelo: str = MODELO_SPACY):
    """
    Carrega o modelo SpaCy para português.

    Tenta carregar o modelo especificado. Se não estiver instalado,
    realiza o download automaticamente via subprocess.

    Args:
        nome_modelo (str): Nome do modelo SpaCy (default: pt_core_news_lg)

    Returns:
        spacy.Language: Objeto de pipeline NLP carregado.

    Raises:
        RuntimeError: Se o download falhar ou o modelo for inválido.
    """
    try:
        nlp = spacy.load(nome_modelo)
        logger.info(f"Modelo SpaCy '{nome_modelo}' carregado com sucesso.")
        return nlp
    except OSError:
        logger.warning(f"Modelo '{nome_modelo}' não encontrado. Iniciando download...")
        resultado = subprocess.run(
            ["python", "-m", "spacy", "download", nome_modelo],
            capture_output=True, text=True
        )
        if resultado.returncode != 0:
            raise RuntimeError(
                f"Falha no download do modelo SpaCy.\n"
                f"STDERR: {resultado.stderr}"
            )
        nlp = spacy.load(nome_modelo)
        logger.info(f"Modelo '{nome_modelo}' baixado e carregado.")
        return nlp


